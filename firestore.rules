rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── 운동 참조 데이터 (읽기 전용 공개 데이터) ────────────────────────────
    // 누구나 읽기 가능, 쓰기는 불가 (import 스크립트는 Admin SDK 사용)

    match /exercises/{exerciseId} {
      allow read: if true;
      allow write: if false;
    }

    match /exerciseCategories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /muscles/{muscleId} {
      allow read: if true;
      allow write: if false;
    }

    match /equipment/{equipmentId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── 사용자 데이터 (본인만 읽기/쓰기) ────────────────────────────────────

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // 운동 기록 로그
      match /workoutLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // 커스텀 운동 종목 (사용자가 추가한 종목)
      match /customExercises/{exerciseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
